{
  "name": "clui",
  "version": "1.0.3",
  "description": "Clui CC — Command Line User Interface for Claude Code",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mthehang/clui-cc.git"
  },
  "bugs": {
    "url": "https://github.com/mthehang/clui-cc/issues"
  },
  "homepage": "https://github.com/mthehang/clui-cc#readme",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "dist": "electron-vite build --mode production && electron-builder --dir",
    "dist:mac": "electron-vite build --mode production && electron-builder --mac --dir",
    "dist:win": "node scripts/download-whisper.js && electron-vite build --mode production && electron-builder --win",
    "dist:win:publish": "node scripts/download-whisper.js && electron-vite build --mode production && electron-builder --win --publish always",
    "doctor": "node scripts/doctor.js",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "electron-updater": "^6.8.3",
    "framer-motion": "^12.35.1",
    "node-pty": "^1.1.0",
    "react-markdown": "^9.0.0",
    "remark-gfm": "^4.0.0",
    "zustand": "^5.0.0"
  },
  "build": {
    "npmRebuild": false,
    "appId": "com.clui.app",
    "publish": {
      "provider": "github",
      "owner": "mthehang",
      "repo": "clui-cc",
      "releaseType": "release"
    },
    "productName": "Clui CC",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/main/**/*",
      "dist/preload/**/*",
      "dist/renderer/**/*",
      "resources/**/*",
      "package.json",
      "node_modules/node-pty/prebuilds/**/*",
      "node_modules/node-pty/lib/**/*",
      "node_modules/node-pty/package.json"
    ],
    "mac": {
      "icon": "resources/icon.icns",
      "entitlements": "resources/entitlements.mac.plist",
      "entitlementsInherit": "resources/entitlements.mac.plist",
      "extendInfo": {
        "NSMicrophoneUsageDescription": "Clui CC uses your microphone to transcribe voice input locally with Whisper."
      }
    },
    "win": {
      "icon": "resources/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "extraResources": [
        {
          "from": "resources/whisper/",
          "to": "whisper",
          "filter": [
            "**/*"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Clui CC",
      "license": "resources/license.txt",
      "installerIcon": "resources/icon.ico",
      "uninstallerIcon": "resources/icon.ico"
    }
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "electron": "^35.7.5",
    "electron-builder": "^26.8.1",
    "electron-vite": "^3.0.0",
    "postcss": "^8.4.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
